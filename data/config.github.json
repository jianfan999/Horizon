{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com/v1",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 3
  },
  "email": {
    "enabled": false
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "torvalds",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "财新网",
        "url": "https://feedx.net/feed/caixin",
        "enabled": true,
        "category": "finance-chinese"
      },
      {
        "name": "虎嗅",
        "url": "https://www.huxiu.com/rss/0.xml",
        "enabled": true,
        "category": "tech-business-chinese"
      },
      {
        "name": "36氪",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "tech-chinese"
      },
      {
        "name": "晚点LatePost",
        "url": "https://www.latepost.com/rss",
        "enabled": true,
        "category": "business-chinese"
      },
      {
        "name": "澎湃新闻",
        "url": "https://www.thepaper.cn/rss",
        "enabled": true,
        "category": "news-chinese"
      },
      {
        "name": "华尔街见闻",
        "url": "https://wallstreetcn.com/rss",
        "enabled": true,
        "category": "finance-chinese"
      },
      {
        "name": "界面新闻",
        "url": "https://www.jiemian.com/rss",
        "enabled": true,
        "category": "business-chinese"
      },
      {
        "name": "Bloomberg Markets",
        "url": "https://feeds.bloomberg.com/markets/news.rss",
        "enabled": true,
        "category": "finance-english"
      },
      {
        "name": "The Economist",
        "url": "https://www.economist.com/finance-and-economics/rss.xml",
        "enabled": true,
        "category": "economics-english"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "tech-english"
      },
      {
        "name": "Rest of World",
        "url": "https://restofworld.org/feed/",
        "enabled": true,
        "category": "global-tech"
      },
      {
        "name": "SCMP",
        "url": "https://www.scmp.com/rss/91/feed",
        "enabled": true,
        "category": "asia-china"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "worldnews",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100
        },
        {
          "subreddit": "technology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "economics",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "geopolitics",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false
  }
}
